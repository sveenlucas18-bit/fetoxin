    "gp_shopify_original_section_603088385485046279": {
      "type": "gp-section-603088385485046279",
      "settings": {
        "section_preload": "true",
        "checksum": "",
        "ggeAvyKSaRH_text": "<p><strong>Viele Produkte setzen auf Druck, Verzicht oder aggressive Inhaltsstoffe. </strong><span style=\"color:#6DC7D7;\"><strong>Fetoxin</strong></span> geht einen anderen Weg: Unterstützung statt Zwang – für Menschen, die sich <strong>langfristig wohlfühlen</strong> möchten.</p>",
        "ggvJ2xhvZXA_childItem_0": "<p>So wirkt Fetoxin</p>",
        "ggRzAkMrAtC_text": "<p>Fetoxin unterstützt den Körper mit ausgewählten Inhaltsstoffen dabei, den Stoffwechsel im Alltag zu begleiten und bewusste Ernährungsroutinen sanft zu ergänzen.</p>",
        "ggUdNu6pnIc_childItem_0": "<p>Inhaltsstoffe</p>",
        "gg4yWgrRIxo_text": "<p>Fetoxin Activity enthält eine sorgfältig abgestimmte Kombination aus Pflanzenextrakten, funktionellen Nährstoffen und Spurenelementen:</p><p>&nbsp;</p><p>Grüntee-Extrakt (standardisiert auf 50 % EGCG)</p><p>Garcinia-Cambogia-Extrakt (standardisiert auf 60 % Hydroxycitronensäure)</p><p>L-Carnitintartrat</p><p>Chrom (als Chrompyridincarboxylat)</p><p>Zink (als Zinkcitrat)</p><p>&nbsp;</p><p><strong>Kapselhülle:</strong> Hydroxypropylmethylcellulose (pflanzlich)</p>"
      }
    },
