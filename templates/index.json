    "gp_shopify_original_section_612201032209924627": {
      "type": "gp-section-612201032209924627",
      "settings": {
        "checksum": "",
        "ggvhuvg_EQX_text": "<p>Gut zu Wissen</p>",
        "ggMCxMzYJSK_text": "Die Vorteile von Fetoxin",
        "gg0Z0FXYx_x_text": "<p>Das Nahrungsergänzugsmittel, das Sie ans Ziel bringt.</p>",
        "ggWT-T1vNTS_childItem_0": "<p>Ausgewählte Wirkstoffe in präziser Dosierung</p>",
        "ggWT-T1vNTS_childItem_1": "<p>Wissenschaftlich basierte Kombination</p>",
        "ggWT-T1vNTS_childItem_2": "<p>Einfach in die tägliche Routine integrierbar</p>",
        "ggsysrP_Rjc_text": "<p>Die Formel kombiniert standardisierte Pflanzenextrakte, L-Carnitin sowie essentielle Spurenelemente. Jede Kapsel enthält exakt abgestimmte Mengen hochwertiger Inhaltsstoffe für eine gleichbleibende Qualität.</p>",
        "ggAOUC5JERm_text": "<p>Grüntee-Extrakt (EGCG), Garcinia-Extrakt (HCA), Chrom und Zink sind sorgfältig kombiniert und orientieren sich an ernährungsphysiologischen Erkenntnissen zu Stoffwechsel und Mikronährstoffen.</p><p>&nbsp;</p>",
        "gghd-eRp92l_text": "<p>Die Kapseln lassen sich unkompliziert in den Alltag einbauen und ergänzen eine bewusste Ernährung sowie einen aktiven Lebensstil – ideal für eine moderne, strukturierte Supplement-Routine.</p>",
        "ggIgRpEH9D3_label": "<p>Jetzt testen</p>"
      }
    },
