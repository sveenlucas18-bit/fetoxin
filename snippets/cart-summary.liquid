{%- doc -%}
  Renders the cart summary totals.

  @param {string} [accelerated_checkout_buttons_layout] - { 'vertical' } Forced layout of the additional checkout buttons, instead of relying on platform's layout.
  @param {string} [drawer_context] - Pass 'drawer' when rendering inside the cart drawer; discount UI is rendered above the product list instead.
{%- enddoc -%}

<div class="cart__summary-totals">
  {%- liquid
    if drawer_context == 'drawer'
      assign currency_symbol = cart.currency.symbol
      assign original_total_price = cart.original_total_price | money_without_currency | append: ' ' | append: currency_symbol
    else
      assign original_total_price = cart.original_total_price | money
    endif
  -%}
  {% # We need to keep this node in place to allow morphing to work properly # %}
  <div class="cart__original-total-container cart-primary-typography">
    {%- if cart.cart_level_discount_applications.size > 0 -%}
      <span class="cart__summary-item cart__original-total">
        <span class="cart__original-total-label">{{ 'content.cart_subtotal' | t }}</span>
        <span class="cart__original-total-value cart-secondary-typography">
          {{- original_total_price -}}
        </span>
      </span>
      <div class="cart__summary-discounts">
        <ul
          class="discounts list-unstyled"
          role="list"
          aria-label="{{ 'content.discounts' | t }}"
        >
          {%- for discount in cart.cart_level_discount_applications -%}
            {%- liquid
              if drawer_context == 'drawer'
                assign discount_total_allocated_amount = discount.total_allocated_amount | money_without_currency | append: ' ' | append: currency_symbol
              else
                assign discount_total_allocated_amount = discount.total_allocated_amount | money
              endif
            -%}
            <li class="cart__summary-item cart__discount">
              <span class="cart__discount-label">
                {{- 'icon-discount.svg' | inline_asset_content -}}
                {{ discount.title | escape }}
              </span>
              <span class="cart__discount-value cart-secondary-typography"
                >-{{ discount_total_allocated_amount -}}
              </span>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  </div>

  {% if settings.show_cart_note or settings.show_add_discount_code %}
    <div class="cart-actions">
      {% if settings.show_cart_note %}
        <script
          type="module"
          src="{{ 'cart-note.js' | asset_url }}"
        ></script>

        <cart-note style="display: flex;">
          <accordion-custom
            class="cart-note"
            {% if settings.cart_note_open_by_default %}
              open-by-default-on-desktop
              open-by-default-on-mobile
            {% endif %}
          >
            <details
              class="details"
              {% if settings.cart_note_open_by_default %}
                open
              {% endif %}
            >
              <summary class="cart-note__summary">
                <span class="cart-note__label cart-primary-typography">
                  {{ 'content.seller_note' | t }}
                </span>

                <span class="svg-wrapper icon-plus">
                  {{- 'icon-plus.svg' | inline_asset_content -}}
                </span>
              </summary>

              <div class="details-content cart-note__inner">
                <label
                  for="cart-note"
                  class="visually-hidden"
                >
                  {{- 'content.seller_note' | t -}}
                </label>
                <textarea
                  form="cart-form"
                  on:input="/updateCartNote"
                  id="cart-note"
                  class="cart-note__instructions"
                  name="note"
                >{{ cart.note }}</textarea>
              </div>
            </details>
          </accordion-custom>
        </cart-note>
      {% endif %}
      {% if settings.show_cart_note and settings.show_add_discount_code and drawer_context != 'drawer' %}
        <div class="cart-actions__divider"></div>
      {% endif %}
      {% if settings.show_add_discount_code %}
        {% unless drawer_context == 'drawer' %}
          {% render 'cart-discount-block', section_id: section.id %}
        {% endunless %}
      {% endif %}
    </div>
  {% endif %}

  {%- liquid
    if drawer_context == 'drawer'
      assign total_price = cart.total_price | money_without_currency | append: ' ' | append: currency_symbol
    elsif settings.currency_code_enabled_cart_total
      assign total_price = cart.total_price | money_with_currency
    else
      assign total_price = cart.total_price | money
    endif
  -%}

  <div class="cart__total-container{% if settings.show_installments %} cart__total-container--has-installments{% endif %}">
    <span
      class="cart__summary-item cart__total"
      role="status"
    >
      <span class="cart__total-label cart-primary-typography">{{ 'content.cart_estimated_total' | t }}</span>
      <text-component
        ref="cartTotal"
        value="{{ total_price | strip_html }}"
        class="cart__total-value cart-secondary-typography"
        {% comment %} Used by payment_terms web component {% endcomment %}
        data-cart-subtotal
      >
        {{ total_price }}
      </text-component>
    </span>
    {% if settings.show_installments %}
      <span class="cart__summary-item cart__installments">
        {% form 'cart', cart %}
          {{ form | payment_terms }}
        {% endform %}
      </span>
    {% endif %}
    <div class="cart__summary-item tax-note cart-primary-typography">
      {% render 'tax-info', has_discounts_enabled: settings.show_add_discount_code %}
    </div>
  </div>
</div>

<div class="cart__ctas">
  <button
    type="submit"
    id="checkout"
    class="cart__checkout-button button"
    name="checkout"
    {% if cart == empty %}
      disabled
    {% endif %}
    form="cart-form"
    style="--button-background-color: #6dc7d7; --button-color: #fff; --button-border-color: transparent; --button-background-hover: #5fb8c6;"
    aria-label="{{ 'content.checkout' | t }} {{ total_price | strip_html }}"
  >
    <span class="cart__checkout-button-inner">
      {{- 'content.checkout' | t -}}
      <span class="cart__checkout-button-total"> {{ total_price }}</span>
    </span>
  </button>

  {% if additional_checkout_buttons and settings.show_accelerated_checkout_buttons and drawer_context != 'drawer' %}
    <div
      class="
        additional-checkout-buttons
        {% if accelerated_checkout_buttons_layout == 'vertical' %}additional-checkout-buttons--vertical{% endif %}
      "
    >
      {{ content_for_additional_checkout_buttons }}
    </div>
  {% endif %}

  {% if settings.cart_drawer_checkout_image != blank %}
    <div class="cart__checkout-image">
      <img
        src="{{ settings.cart_drawer_checkout_image | image_url: width: 800 }}"
        alt="{{ settings.cart_drawer_checkout_image.alt | default: '' }}"
        width="{{ settings.cart_drawer_checkout_image.width }}"
        height="{{ settings.cart_drawer_checkout_image.height }}"
        loading="lazy"
      >
    </div>
  {% endif %}

  {% if settings.cart_drawer_badge_text_1 != blank or settings.cart_drawer_badge_text_2 != blank %}
    <ul class="cart__trust-badges list-unstyled">
      {% if settings.cart_drawer_badge_text_1 != blank %}
        <li class="cart__trust-badge">
          <span class="cart__trust-badge-check" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <span class="cart__trust-badge-text">{{ settings.cart_drawer_badge_text_1 }}</span>
        </li>
      {% endif %}
      {% if settings.cart_drawer_badge_text_2 != blank %}
        <li class="cart__trust-badge">
          <span class="cart__trust-badge-check" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <span class="cart__trust-badge-text">{{ settings.cart_drawer_badge_text_2 }}</span>
        </li>
      {% endif %}
    </ul>
  {% endif %}
</div>

{% stylesheet %}
  .cart-actions {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-block: 1px solid var(--color-border);
    padding-block: 0;
    margin-block-start: var(--margin-3xs);
  }

  .cart-actions__divider {
    border-block-start: 1px solid var(--color-border);
  }

  .cart__summary-totals:not(:has(.cart-actions)) {
    margin-block-start: var(--margin-3xs);
    border-block-start: 1px solid var(--color-border);
    padding-block-start: var(--margin-xl);
  }

  .cart__installments {
    color: var(--color-foreground);
    font-size: var(--cart-font-size--2xs);
  }

  .cart-discount__input {
    background-color: var(--color-input-background);
    color: var(--color-input-text);
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    padding: var(--padding-sm) var(--padding-md);
    height: 100%;
    flex-grow: 1;
    min-width: 0;
    font-size: var(--cart-font-size--sm);
  }

  .cart-discount__input::placeholder {
    color: #9e9e9e;
  }

  .cart-discount__pill-code {
    overflow: hidden;
    max-width: 120px;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin: 0;
    font-size: var(--cart-font-size--sm);
    font-weight: 500;
    color: #2d6a6f;
  }

  .cart-discount {
    width: 100%;
  }

  .cart-discount .svg-wrapper {
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
  }

  .cart-discount__codes {
    display: none;
    gap: var(--padding-xs);
    flex-wrap: wrap;
    list-style: none;
    padding-inline: 0;
    margin: 0;
    padding-block-start: var(--padding-xs);
  }

  .cart-discount__codes:has(.cart-discount__pill) {
    display: flex;
  }

  .cart-discount__button {
    height: 100%;
    color: #fff;
    border: none;
    border-radius: 5px;
    background: #6DC7D7;
    font-weight: 700;
    padding-inline: var(--padding-md);
    flex-shrink: 0;
  }

  .cart-discount__button:hover {
    background-color: #5fb8c6;
  }

  .cart-discount__content {
    height: calc(var(--button-size) + var(--padding-2xs) + var(--padding-sm));
  }

  .cart-discount__pill {
    display: inline-flex;
    align-items: center;
    gap: var(--padding-xs);
    padding: var(--padding-xs) var(--padding-sm);
    border-radius: 6px;
    background-color: #e0f7fa;
    border: 1px solid #76c8d5;
  }

  .cart-discount__pill-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    border-radius: 50%;
    background-color: #76c8d5;
    color: #fff;
  }

  .cart-discount__pill-check svg {
    width: 12px;
    height: 12px;
  }

  .cart-discount__pill-remove {
    --close-icon-opacity: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    border-radius: 50%;
    background-color: #76c8d5;
    color: #fff;
    padding: 0;
    border: none;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .cart-discount__pill-remove:hover {
    background-color: #5fb8c6;
    color: #fff;
  }

  .cart-discount__pill-remove svg {
    width: 12px;
    height: 12px;
  }

  .cart-discount__form {
    display: flex;
    gap: var(--padding-sm);
    align-items: center;
    height: 100%;
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  .cart-discount__error {
    display: flex;
    align-items: center;
    width: 100%;
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  .cart-discount__error .svg-wrapper {
    flex-shrink: 0;
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
    margin-inline: var(--margin-3xs) var(--margin-xs);
  }

  .cart-discount__error-text {
    margin-block-start: var(--margin-3xs);
  }

  .cart-discount--always-open .cart-discount__form {
    padding-block-start: 0;
  }

  /* Checkout CTA: keep teal + white text even when .button vars resolve late (morph / FOUC) */
  .cart__ctas {
    width: 100%;
    display: grid;
    gap: var(--checkout-button-gap, 10px);
    grid-auto-flow: row;
    grid-template-columns: 1fr;
  }

  .cart__additional-checkout-buttons {
    width: 100%;
  }

  .cart__ctas .cart__checkout-button {
    width: 100%;
    height: clamp(25px, var(--height-buy-buttons), 55px);
    padding-inline: var(--padding-4xl);
    border-radius: 10px;
    font-size: 16px;
    font-weight: 700;
    color: #fff !important;
    background-color: #6dc7d7 !important;
    box-shadow: none !important;
  }

  .cart__checkout-button:hover:not(:disabled) {
    color: #fff !important;
    background-color: #5fb8c6 !important;
  }

  .cart__checkout-button:disabled,
  .cart__checkout-button[aria-disabled='true'] {
    opacity: 0.5;
    cursor: not-allowed;
    color: #fff !important;
    background-color: #6dc7d7 !important;
  }

  .cart__checkout-button-inner {
    display: inline;
  }

  .cart__checkout-button-total {
    font-weight: 700;
  }

  shopify-accelerated-checkout-cart {
    --shopify-accelerated-checkout-inline-alignment: center;
    --shopify-accelerated-checkout-button-border-radius: var(--style-border-radius-buttons-primary);
    --shopify-accelerated-checkout-row-gap: var(--checkout-button-gap, 10px);
  }

  .cart__checkout-image {
    width: 100%;
    margin-block-start: var(--margin-sm, 12px);
    text-align: center;
  }

  .cart__checkout-image img {
    display: inline-block;
    max-width: 100%;
    height: auto;
  }

  .cart__trust-badges {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-block-start: 14px;
    padding: 0;
  }

  .cart__trust-badge {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .cart__trust-badge-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #333;
  }

  .cart__trust-badge-text {
    font-size: var(--cart-font-size--sm, 14px);
    color: #333;
    font-weight: 500;
  }
{% endstylesheet %}
